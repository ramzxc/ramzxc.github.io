rCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"62"},{"filePath":"63","messages":"64","suppressedMessages":"65","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"66","messages":"67","suppressedMessages":"68","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"69","messages":"70","suppressedMessages":"71","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"72","messages":"73","suppressedMessages":"74","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"75","messages":"76","suppressedMessages":"77","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"78","messages":"79","suppressedMessages":"80","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"81","messages":"82","suppressedMessages":"83","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"84","messages":"85","suppressedMessages":"86","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\index.js",[],[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\App.js",[],["87","88","89"],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\reportWebVitals.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\Main.js",["90","91","92","93"],[],"import { Link } from 'react-router-dom';\r\nimport { BrowserRouter, Route, Routes } from 'react-router-dom';\r\nimport \"/\"\r\n\r\nconst Main = () => {\r\n    return (\r\n        <div className=\"content\">\r\n\t\t\t<h2 className=\"category\">about me</h2>\r\n\r\n            <h3 className='title'>Introduce Myself</h3>\r\n\t\t\t<p>한양대학교 컴퓨터소프트웨어학부 23학번</p>\r\n\t\t\t<p>윤아람</p>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n        </div>\r\n    )\r\n};\r\n\r\nexport default Main;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\Sidebar.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Algorithms.js",["94"],[],"import \"../../Content.css\"\r\n\r\nconst d = <div className=\"f\"></div>\r\n\r\nconst Algorithms = () => {\r\n\treturn (\r\n\t\t<div className=\"content\">\r\n\t\t\t<h2 className=\"category\">Algorithms</h2>\r\n\t\t\t\r\n\t\t\t<br></br>\r\n\t\t\t<p>No posts yet</p>\r\n\t\t\t{/* <h1 className=\"title\">test</h1>\r\n\t\t\t<p>test content</p>\r\n\t\t\t<a className=\"date\">2023-07-03</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d} */}\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default Algorithms;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\programming\\Web.js",["95"],[],"import '../../Content.css';\r\nimport { Link } from 'react-router-dom';\r\n\r\nconst d = <div className=\"f\"></div>\r\n\r\nconst Web = () => {\r\n\treturn (\r\n\t\t<div className=\"content\">\r\n\t\t\t<h2 className=\"category\"><Link exact to='/programming/web'>Web</Link></h2>\r\n\t\t\t<br></br>\r\n\t\t\t<p>No posts yet</p>\r\n\r\n\t\t\t{/* <h1 className='title'>깃허브 블로그 새로고침 문제 해결</h1>\r\n\t\t\t<p>깃허브 페이지는 React의 SPA(Single Page Application)를 지원하지 않는다.</p> \r\n\t\t\t<p>그래서 다른 페이지로 이동 (엄밀히 말해서 이동은 아닐 테지만) 후 새로고침 시 얘가 주소를 찾지 못해 404 에러를 띄우게 된다.</p>\r\n\t\t\t<p>이 문제를 해결하는 데에는 크게 두 가지 방법이 있다.</p>\r\n\t\t\t<p>첫째, 검색엔진이 읽지 못하나 #(해쉬값) 이전의 주소를 제외하면 \r\n\t\t\t\t에초에 서버에 요청이 가지 않아 백엔드 서버가 없는 정적인 페이지에 주로 사용되는 HashRouter를 사용하기.</p>\r\n\t\t\t<p>둘째는 404.html을 생성 후 그 안에 스크립트를 만들어 리디렉션하기이다.</p>\r\n\t\t\t<p>원래는 두번째 것으로 멋지게 새로고침 문제를 해결하려 했으나 해보려다가 조금 귀찮아져서 손쉬운 첫번째 방법을 택했다.</p>\r\n\t\t\t<p>어차피 옮길 블로그, 검색엔진이 찾을 수 있든 없든 상관없지 않을까?</p>\r\n\t\t\t<p>뭐, 나중에 웹에 대한 이해도가 더 나아지면 두번째 방법을 다시 시도할 여지도 충분하니 말이다.</p>\r\n\t\t\t<p>첫 번째 방법은 단순히 BrowswerRouter -&gt; HashRouter 이렇게 바꿔주면 되는거라 복잡한 설명같은 것도 필요 없다.</p>\r\n\t\t\t<p>이 얼마나 단순하고 아름다운가!</p>\r\n\t\t\t<a className=\"date\">Jul. 5th, 2023</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d}\r\n\r\n\t\t\t<h1 className=\"title\">생애 첫 블로그 만들기</h1>\r\n\t\t\t<p>깃허브에서 제공하는 기능을 통해 무료로 커스터마이징이 가능한 블로그를 운영할 수 있게 되었다.</p>\r\n\t\t\t<p>그래서 만들어 보았다!</p>\r\n\t\t\t<p>그렇게 나는 React도 연습할 겸, React를 통해 그리 어렵지 않게, 단순한 형태의 블로그를 완성할 수 있었다.</p>\r\n\t\t\t<p>그런데 문제는, 이 깃허브 블로그는 정적 웹 페이지이기 때문에 DB연동 등과 같은 일부 기능을 이용할 수가 없다.</p>\r\n\t\t\t<p>그래서 채택한 방법이 있다. 글을 쓸 때 직접 vscode를 열어서 마치 코딩하는 것처럼 불편하게 작성하는 것이다!</p>\r\n\t\t\t<p>이걸로 좀 쓰다가 워드프레스나 티스토리나 뭐 이런걸로 넘어가야지..</p>\r\n\t\t\t<a className=\"date\">Jul. 3rd, 2023</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d} */}\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default Web;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\BOJ.js",["96","97","98"],[],"import '../../Content.css';\r\nimport Highlight from 'react-highlight';\r\n\r\nconst BOJ = () => {\r\n\treturn (\r\n\t\t<div className='content'>\r\n\t\t\t<h2 className='category'>BOJ</h2>\r\n\t\t\t<br></br>\r\n\t\t\t\r\n\t\t\t<h1 className='title'>2616번: 소형기관차</h1>\r\n\t\t\t<a onClick={() => window.open(\"https://www.acmicpc.net/problem/2616\")}>https://www.acmicpc.net/problem/2616</a>\r\n\t\t\t<p>배열이 주어질 때, 이 배열 안에서 연속된 세 개의 부분합이 최대가 될 경우를 구하는 문제이다. 부분합의 길이는 입력으로 주어진다.</p>\r\n\t\t\t<p>우선 누적합을 통해 특정 길이의 부분합을 구해놓고, DP 알고리즘을 사용해 문제를 어렵지 않게 해결할 수 있다. DP의 정석 같은 느낌을 받았달까.</p>\r\n\t\t\t<img src=\"/img/2616.png\"/>\r\n\t\t\t<p>DP를 통해 지금까지의 최댓값 (dp[i][j - 1]) 과 현재 위치를 선택해 계산한 값 (dp[i - 1][j - t] + s) 을 비교하여 더 큰 값을 dp[i][j]에 저장한다.</p>\r\n\t\t\t<p>이렇게 되면 항상 현재 값은 현재까지의 계산 중 최댓값이 되며 그렇기에 가장 마지막 값이 모든 배열을 고려했을 때의 최댓값이 되게 된다. DP의 기본적인 원리이기도 하다.</p>\r\n\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default BOJ;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Codeforces.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Contests.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\programming\\Game.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\games\\NS.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\games\\Steam.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\games\\Chess.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\cybersecurity\\Cybersecurity.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\Books\\BR.js",[],[],{"ruleId":"99","severity":1,"message":"100","line":4,"column":10,"nodeType":"101","messageId":"102","endLine":4,"endColumn":18,"suppressions":"103"},{"ruleId":"99","severity":1,"message":"104","line":5,"column":10,"nodeType":"101","messageId":"102","endLine":5,"endColumn":20,"suppressions":"105"},{"ruleId":"106","severity":1,"message":"107","line":30,"column":43,"nodeType":"108","endLine":30,"endColumn":63,"suppressions":"109"},{"ruleId":"99","severity":1,"message":"110","line":1,"column":10,"nodeType":"101","messageId":"102","endLine":1,"endColumn":14},{"ruleId":"99","severity":1,"message":"111","line":2,"column":10,"nodeType":"101","messageId":"102","endLine":2,"endColumn":23},{"ruleId":"99","severity":1,"message":"112","line":2,"column":25,"nodeType":"101","messageId":"102","endLine":2,"endColumn":30},{"ruleId":"99","severity":1,"message":"113","line":2,"column":32,"nodeType":"101","messageId":"102","endLine":2,"endCol