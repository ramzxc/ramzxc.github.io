"mtime":1689349240642,"results":"25","hashOfConfig":"18"},{"size":286,"mtime":1688564224843,"results":"26","hashOfConfig":"18"},{"size":280,"mtime":1688564226927,"results":"27","hashOfConfig":"18"},{"size":268,"mtime":1688564213495,"results":"28","hashOfConfig":"18"},{"size":275,"mtime":1688564209732,"results":"29","hashOfConfig":"18"},{"size":269,"mtime":1688564211720,"results":"30","hashOfConfig":"18"},{"size":271,"mtime":1688564208438,"results":"31","hashOfConfig":"18"},{"size":295,"mtime":1688564202630,"results":"32","hashOfConfig":"18"},{"size":270,"mtime":1688566253726,"results":"33","hashOfConfig":"18"},{"filePath":"34","messages":"35","suppressedMessages":"36","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},"bp95c",{"filePath":"38","messages":"39","suppressedMessages":"40","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"41","messages":"42","suppressedMessages":"43","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"44","messages":"45","suppressedMessages":"46","errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"47","usedDeprecatedRules":"37"},{"filePath":"48","messages":"49","suppressedMessages":"50","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"51","messages":"52","suppressedMessages":"53","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"54","usedDeprecatedRules":"37"},{"filePath":"55","messages":"56","suppressedMessages":"57","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"58","usedDeprecatedRules":"37"},{"filePath":"59","messages":"60","suppressedMessages":"61","errorCount":0,"fatalErrorCount":0,"warningCount":16,"fixableErrorCount":0,"fixableWarningCount":0,"source":"62"},{"filePath":"63","messages":"64","suppressedMessages":"65","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"66","messages":"67","suppressedMessages":"68","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"69","messages":"70","suppressedMessages":"71","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"72","messages":"73","suppressedMessages":"74","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"75","messages":"76","suppressedMessages":"77","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"78","messages":"79","suppressedMessages":"80","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"81","messages":"82","suppressedMessages":"83","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},{"filePath":"84","messages":"85","suppressedMessages":"86","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"37"},"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\index.js",[],[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\App.js",[],["87","88","89","90","91","92"],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\reportWebVitals.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\Main.js",["93","94","95","96"],[],"import { Link } from 'react-router-dom';\r\nimport { BrowserRouter, Route, Routes } from 'react-router-dom';\r\nimport \"/\"\r\n\r\nconst Main = () => {\r\n    return (\r\n        <div className=\"content\">\r\n\t\t\t<h2 className=\"category\">about me</h2>\r\n\r\n            <h3 className='title'>Introduce Myself</h3>\r\n\t\t\t<p>한양대학교 컴퓨터소프트웨어학부 23학번</p>\r\n\t\t\t<p>윤아람</p>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n        </div>\r\n    )\r\n};\r\n\r\nexport default Main;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\Sidebar.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Algorithms.js",["97"],[],"import \"../../Content.css\"\r\n\r\nconst d = <div className=\"f\"></div>\r\n\r\nconst Algorithms = () => {\r\n\treturn (\r\n\t\t<div className=\"content\">\r\n\t\t\t<h2 className=\"category\">Algorithms</h2>\r\n\t\t\t\r\n\t\t\t<br></br>\r\n\t\t\t<p>No posts yet</p>\r\n\t\t\t{/* <h1 className=\"title\">test</h1>\r\n\t\t\t<p>test content</p>\r\n\t\t\t<a className=\"date\">2023-07-03</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d} */}\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default Algorithms;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\programming\\Web.js",["98"],[],"import '../../Content.css';\r\nimport { Link } from 'react-router-dom';\r\n\r\nconst d = <div className=\"f\"></div>\r\n\r\nconst Web = () => {\r\n\treturn (\r\n\t\t<div className=\"content\">\r\n\t\t\t<h2 className=\"category\"><Link exact to='/programming/web'>Web</Link></h2>\r\n\t\t\t<br></br>\r\n\t\t\t<p>No posts yet</p>\r\n\r\n\t\t\t{/* <h1 className='title'>깃허브 블로그 새로고침 문제 해결</h1>\r\n\t\t\t<p>깃허브 페이지는 React의 SPA(Single Page Application)를 지원하지 않는다.</p> \r\n\t\t\t<p>그래서 다른 페이지로 이동 (엄밀히 말해서 이동은 아닐 테지만) 후 새로고침 시 얘가 주소를 찾지 못해 404 에러를 띄우게 된다.</p>\r\n\t\t\t<p>이 문제를 해결하는 데에는 크게 두 가지 방법이 있다.</p>\r\n\t\t\t<p>첫째, 검색엔진이 읽지 못하나 #(해쉬값) 이전의 주소를 제외하면 \r\n\t\t\t\t에초에 서버에 요청이 가지 않아 백엔드 서버가 없는 정적인 페이지에 주로 사용되는 HashRouter를 사용하기.</p>\r\n\t\t\t<p>둘째는 404.html을 생성 후 그 안에 스크립트를 만들어 리디렉션하기이다.</p>\r\n\t\t\t<p>원래는 두번째 것으로 멋지게 새로고침 문제를 해결하려 했으나 해보려다가 조금 귀찮아져서 손쉬운 첫번째 방법을 택했다.</p>\r\n\t\t\t<p>어차피 옮길 블로그, 검색엔진이 찾을 수 있든 없든 상관없지 않을까?</p>\r\n\t\t\t<p>뭐, 나중에 웹에 대한 이해도가 더 나아지면 두번째 방법을 다시 시도할 여지도 충분하니 말이다.</p>\r\n\t\t\t<p>첫 번째 방법은 단순히 BrowswerRouter -&gt; HashRouter 이렇게 바꿔주면 되는거라 복잡한 설명같은 것도 필요 없다.</p>\r\n\t\t\t<p>이 얼마나 단순하고 아름다운가!</p>\r\n\t\t\t<a className=\"date\">Jul. 5th, 2023</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d}\r\n\r\n\t\t\t<h1 className=\"title\">생애 첫 블로그 만들기</h1>\r\n\t\t\t<p>깃허브에서 제공하는 기능을 통해 무료로 커스터마이징이 가능한 블로그를 운영할 수 있게 되었다.</p>\r\n\t\t\t<p>그래서 만들어 보았다!</p>\r\n\t\t\t<p>그렇게 나는 React도 연습할 겸, React를 통해 그리 어렵지 않게, 단순한 형태의 블로그를 완성할 수 있었다.</p>\r\n\t\t\t<p>그런데 문제는, 이 깃허브 블로그는 정적 웹 페이지이기 때문에 DB연동 등과 같은 일부 기능을 이용할 수가 없다.</p>\r\n\t\t\t<p>그래서 채택한 방법이 있다. 글을 쓸 때 직접 vscode를 열어서 마치 코딩하는 것처럼 불편하게 작성하는 것이다!</p>\r\n\t\t\t<p>이걸로 좀 쓰다가 워드프레스나 티스토리나 뭐 이런걸로 넘어가야지..</p>\r\n\t\t\t<a className=\"date\">Jul. 3rd, 2023</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d} */}\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default Web;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\BOJ.js",["99","100","101","102","103","104","105","106","107","108","109","110","111","112","113","114"],[],"import '../../Content.css';\r\n\r\nconst BOJ = () => {\r\n\treturn (\r\n\t\t<div className='content'>\r\n\t\t\t<h2 className='category'>BOJ</h2>\r\n\t\t\t<br></br>\r\n\r\n\t\t\t<h1 id='2169' className='title'>2169번: 로봇 조종하기</h1>\r\n\t\t\t<a onClick={() => window.open(\"https://www.acmicpc.net/problem/2169\")}>https://www.acmicpc.net/problem/2169</a>\r\n\t\t\t<p>문제의 조건 중 '왼쪽으로 갈 수 있다'는 점 때문에 조금 더 고민해야 했지만 큰 역경 없이 무난하게 해결할 수 있었던 문제다. 구현 실력을 조금만 더 키워 문제를 더 빨리 해결할 수 있으면 좋을듯.</p>\r\n\t\t\t<img src='img/2169.png' style={{height: '500px'}}/>\r\n\t\t\t<p>이 문제가 DP인 이유는, (1, 1)부터 (N, M)까지의 도달하는 과정을 작은 경로들로 쪼개어 계산해서 연속적으로 합칠 수 있기 때문이다.</p>\r\n\t\t\t<p>이번 문제의 경우 (i, j)까지의 가장 작은 거리를 가지는 경로는 (i - 1, j) -{'>'} (i, j), (i, j - 1) -{'>'} (i, j), (i, j + 1) -{'>'} (i, j) 이렇게 세 가지 경우가 있을 수 있다.</p>\r\n\t\t\t<p>이러한 경우들을 올바르게 나누어 구현하면 정답을 맞출 수 있을 것이다.</p>\r\n\t\t\t<p>dp배열을 삼차원으로 설정해서, dp[i][j][0]에는 오른쪽으로 갈 때의 가치 최댓값, dp[i][j][1]에는 왼쪽으로 갈 때의 가치 최댓값을 저장해주었다.</p>\r\n\t\t\t<p>문제에서 한 번 간 곳은 두 번 다시 갈 수 없다고 했기 때문에, 오른쪽으로 갔다가 다시 왼쪽으로 가는 경우의 수는 존재하지 않게 된다.</p>\r\n\t\t\t<p>그렇기 때문에 dp[i][j][0]의 값은 dp[i][j - 1][0]과 dp[i - 1][j][0], dp[i - 1][j][1]의 값에만, dp[i][j][1]도 마찬가지로 dp[i][j + 1][0], dp[i - 1][j][0], dp[i - 1][j][1]의 값에만 영향을 받게 된다.</p>\r\n\t\t\t<p>그래서 이 둘을 동시에 계산하여 최적값(가치가 최대가 되는 값)을 구할 수 있다.</p>\r\n\t\t\t<a className=\"date\">Jul. 14th, 2023</a>\r\n\r\n\t\t\t<h1 id='1915' className='title'>1915번: 가장 큰 정사각형</h1>\r\n\t\t\t<a onClick={() => window.open(\"https://www.acmicpc.net/problem/1915\")}>https://www.acmicpc.net/problem/1915</a>\r\n\t\t\t<p>예전에 풀어봤던 문제였는지 보자마자 풀이를 떠올릴 수 있었다. 여담으로 질문 게시판 탭에 습관적으로 들어갔다가 '답 정사각형의 길이로 해서 틀리시는 분들'이라는 제목만 읽고 \"설마 내가 저렇게 틀리겠어?\" 했는데 진짜 그렇게 틀려서 웃겼다.</p>\r\n\t\t\t<img src='/img/1915.png'/>\r\n\t\t\t<p>밑에서 풀었던 문제들과는 그때그때마다 rmax로 최댓값을 찾아줘야한다는 것 말고는 크게 다른 점 없는 무난한 DP 문제인 것 같다.</p>\r\n\t\t\t<p>rmax로 최댓값을 찾아야 하는 이유는 밑의 문제들과는 다르게 배열 전체가 '연속적'으로 고려되지 않고, 부분부분만 연속적으로 고려되기 때문이다.</p>\r\n\t\t\t<p>배열을 돌며 우선 현재 위치의 배열이 값 1을 가지고 있는지 확인한 후 자신을 기준으로 대각선 왼쪽 한 칸 위, 왼쪽 한 칸 전, 위쪽으로 한 칸 전을 검사해 이미 만들어진 정사각형이 있는지 확인한다.</p>\r\n\t\t\t<p>arr[i][j]에 저장되는 값은 정사각형의 길이로, 정사각형 자체가 또 다른 작은 정사각형들로 이루어져 있다는 점을 이용해 만약 검사한 위 세 개의 칸 중 최솟값에 현재 위치 arr[i][j]의 길이 1을 더해줌으로써 반드시 정사각형을 만들 수 있게 된다. </p>\r\n\t\t\t<a className=\"date\">Jul. 13th, 2023</a>\r\n\t\t\t<br></br>\r\n\t\t\t\r\n\t\t\t<h1 id='11049' className='title'>11049번: 행렬 곱셈 순서</h1>\r\n\t\t\t<a onClick={() => window.open(\"https://www.acmicpc.net/problem/11049\")}>https://www.acmicpc.net/problem/11049</a>\r\n\t\t\t<p>노린 건 아니었지만 밑의 11066번과 풀이 방법이 완전히 똑같다고 볼 수 있는 문제였다.</p>\r\n\t\t\t<img src='/img/11049.png'/>\r\n\t\t\t<p>마찬가지로 동적계획법, DP를 이용해 문제들을 잘게 쪼갠 뒤 합치는 방법으로 풀 수 있으며 등장하는 s, e, k의 역할이 11066번과 완전히 동일히다.</p>\r\n\t\t\t<p>시작지점 s, 끝지점 e와 행렬을 합칠 때는 무조건 두개씩 합친다는 점, 그리고 행렬이 결국 하나로 합쳐진다는 점을 이용해서 k번째에서 행렬이 둘로 나뉘어 합쳐질 때의 값을 저장해나간다.</p>\r\n\t\t\t<p>작은 것부터 시작하기 때문에 합치는 행렬의 수가 2개일 때부터 3개, 4개, 결국 하나로 합쳐질 때까지 반복해준다. </p>\r\n\t\t\t<a className=\"date\">Jul. 11th, 2023</a>\r\n\t\t\t<br></br>\r\n\r\n\t\t\t<h1 id='11066' className='title'>11066번: 파일 합치기</h1>\r\n\t\t\t<a onClick={() => window.open(\"https://www.acmicpc.net/problem/11066\")}>https://www.acmicpc.net/problem/11066</a>\r\n\t\t\t<p>이번 문제도 전형적인 DP 문제였는데, 워낙 오랜만이다보니 조금 해맸다. <a onClick={() => window.open(\"https://tjdahr25.tistory.com/m/45\")}>이 블로그</a>를 참고해서 문제 풀이에 성공할 수 있었다.</p>\r\n\t\t\t<img src='/img/11066.png'/>\r\n\t\t\t<p>우선 이 문제는 큰 문제를 작은 문제들로 쪼개는 DP 기법을 통해 풀 수 있는데, 결국 합쳐지는 파일이 항상 두개씩이고 모든 파일을 합쳐 하나로 만들어야 하기 때문이다.</p>\r\n\t\t\t<p>그렇다면 주어진 파일들의 시작점과 끝점을 s, e로 잡고 배열 dp[s][e]는 시작점 s부터 e까지의 파일 크기로 정해 문제를 풀 수 있다.</p>\r\n\t\t\t<p>지금 합치고자 하는 파일이 s부터 e까지라면, 그 파일들은 s부터 k까지, 또 k + 1부터 e까지 합친 파일들의 합으로 정의할 수 있다.</p>\r\n\t\t\t<p>k값에 따라 파일의 크기가 달라지기 때문에 우리는 k값을 변화시켜가며 최솟값을 취하면 된다.</p>\r\n\t\t\t<a className=\"date\">Jul. 9th, 2023</a>\r\n\t\t\t<br></br>\r\n\t\t\t\r\n\t\t\t<h1 id='2616' className='title'>2616번: 소형기관차</h1>\r\n\t\t\t<a onClick={() => window.open(\"https://www.acmicpc.net/problem/2616\")}>https://www.acmicpc.net/problem/2616</a>\r\n\t\t\t<p>배열이 주어질 때, 이 배열 안에서 연속된 세 개의 부분합이 최대가 될 경우를 구하는 문제이다. 부분합의 길이는 입력으로 주어진다.</p>\r\n\t\t\t<p>우선 누적합을 통해 특정 길이의 부분합을 구해놓고, DP 알고리즘을 사용해 문제를 어렵지 않게 해결할 수 있다. DP의 정석 같은 느낌을 받았달까.</p>\r\n\t\t\t<img src=\"/img/2616.png\"/>\r\n\t\t\t<p>DP를 통해 지금까지의 최댓값 (dp[i][j - 1]) 과 현재 위치를 선택해 계산한 값 (dp[i - 1][j - t] + s) 을 비교하여 더 큰 값을 dp[i][j]에 저장한다.</p>\r\n\t\t\t<p>이렇게 되면 항상 현재 값은 현재까지의 계산 중 최댓값이 되며 그렇기에 가장 마지막 값이 모든 배열을 고려했을 때의 최댓값이 되게 된다.</p>\r\n\t\t\t<a className=\"date\">Jul. 8th, 2023</a>\r\n\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t\t<br></br>\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default BOJ;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Codeforces.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Contests.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\programming\\Game.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\games\\NS.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\games\\Steam.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\games\\Chess.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\cybersecurity\\Cybersecurity.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\Books\\BR.js",[],[],{"ruleId":"115","severity":1,"message":"116","line":4,"column":10,"nodeType":"117","messageId":"118","endLine":4,"endColumn":18,"suppressions":"119"},{"ruleId":"115","severity":1,"message":"120","line":5,"column":10,"nodeType":"117","messageId":"118","endLine":5,"endColumn":20,"suppressions":"121"},{"ruleId":"122","severity":1,"message":"123","line":30,"column":43,"nodeType":"124","endLine":30,"endColumn":63,"suppressions":"125"},{"ruleId":"126","severity":1,"message":"127","line":34,"column":30,"nodeType":"124","endLine":34,"endColumn":95,"suppressions":"128"},{"ruleId":"126","severity":1,"message":"127","line":35,"column":30,"nodeType":"124","endLine":35,"endColumn":94,"suppressions":"129"},{"ruleId":"126","severity":1,"message":"127","line":36,"column":30,"nodeType":"124","endLine":36,"endColumn":82,"suppressions":"130"},{"ruleId":"115","severity":1,"message":"131","line":1,"column":10,"nodeType":"117","messageId":"118","endLine":1,"endColumn":14},{"ruleId":"115","severity":1,"message":"132","line":2,"column":10,"nodeType":"117","messageId":"118","endLine":2,"endColumn":23},{"ruleId":"115","severity":1,"message":"133","line":2,"column":25,"nodeType":"117","messageId":"118","endLine":2,"endColumn":30},{"ruleId":"115","severity":1,"message":"134","line":2,"column":32,"nodeType":"117","messageId":"118","endLine":2,"endColumn":38},{"ruleId":"115","severity":1,"message":"135","line":3,"column":7,"nodeType":"117","messageId":"118","endLine":3,"endColumn":8},{"ruleId":"115","severity":1,"message":"135","line":4,"column":7,"nodeType":"117","messageId":"118","endLine":4,"endColumn":8},{"ruleId":"122","severity":1,"message":"123","line":10,"column":4,"nodeType":"124","endLine":10,"endColumn":75},{"ruleId":"126","severity":1,"message":"127","line":12,"column":4,"nodeType":"124","endLine":12,"endColumn":55},{"ruleId":"122","severity":1,"message":"123","line":20,"column":4,"nodeType":"124","endLine":20,"endColumn":24},{"ruleId":"122","severity":1,"message":"123","line":23,"column":4,"nodeType":"124","endLine":23,"endColumn":75},{"ruleId":"126","severity":1,"message":"127","line":25,"column":4,"nodeType":"124","endLine":25,"endColumn":30},{"ruleId":"122","severity":1,"message":"123","line":30,"column":4,"nodeType":"124","endLine":30,"endColumn":24},{"ruleId":"122","severity":1,"message":"123","line":34,"column":4,"nodeType":"124","endLine":34,"endColumn":76},{"ruleId":"126","severity":1,"message":"127","line":36,"column":4,"nodeType":"124","endLine":36,"endColumn":31},{"ruleId":"122","severity":1,"message":"123","line":40,"column":4,"nodeType":"124","endLine":40,"endColumn":24},{"ruleId":"122","severity":1,"message":"123","line":44,"column":4,"nodeType":"124","endLine":44,"endColumn":76},{"ruleId":"122","severity":1,"message":"123","line":45,"column":48,"nodeType":"124","endLine":45,"endColumn":116},{"ruleId":"126","severity":1,"message":"127","line":46,"column":4,"nodeType":"124","endLine":46,"endColumn":31},{"ruleId":"122","severity":1,"message":"123","line":51,"column":4,"nodeType":"124","endLine":51,"endColumn":24},{"ruleId":"122","severity":1,"message":"123","line":55,"column":4,"nodeType":"124","endLine":55,"endColumn":75},{"ruleId":"126","severity":1,"message":"127","line":58,"column":4,"nodeType":"124","endLine":58,"endColumn":30},{"ruleId":"122","severity":1,"message":"123","line":61,"column":4,"nodeType":"124","endLine":61,"endColumn":24},"no-unused-vars","'useState' is defined but never used.","Identifier","unusedVar",["136"],"'HashRouter' is defined but never used.",["137"],"jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","JSXOpeningElement",["138"],"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.",["139"],["140"],["141"],"'Link' is defined but never used.","'BrowserRouter' is defined but never used.","'Route' is defined but never used.","'Routes' is defined but never used.","'d' is assigned a value but never used.",{"kind":"142","justification":"143"},{"kind":"142","justification":"143"},{"kind":"142","justification":"143"},{"kind":"142","justification":"143"},{"kind":"142","justification":"143"},{"kind":"142","justification":"143"},"directive",""]