bar.css';\r\n\r\nconst Sidebar = () => {\r\n    return (\r\n        <div className='sidebar'>\r\n\t\t\t <div className='divider' id='search'>\r\n\t\t\t\t<p>About me</p>\r\n\t\t\t </div>\r\n\t\t\t <div className='contents'>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li><Link exact to='/'>Introduce Myself</Link></li>\r\n\t\t\t\t</ul>\r\n\t\t\t </div>\r\n\t\t\t <div className='divider'>\r\n\t\t\t\t<p>recent posts</p>\r\n\t\t\t </div>\r\n\t\t\t <div className='contents'>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li><Link exact to='/programming/web'>생애 첫 블로그 만들기</Link></li>\r\n\t\t\t\t</ul>\r\n\t\t\t </div>\r\n\t\t\t <div className='divider'>\r\n\t\t\t\t<p>categories</p>\r\n\t\t\t </div>\r\n\t\t\t <div className='contents'>\r\n\t\t\t\t<ul>\r\n\t\t\t\t\t<li>Problem Solving</li>\r\n\t\t\t\t\t{/* <li><Link exact to='/ps'>Problem Solving</Link></li> */}\r\n\t\t\t\t\t<br></br>\r\n\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<li><Link exact to='/ps/algorithms'>Algorithms</Link></li>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/ps/BOJ'>BOJ</Link></li>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/ps/codeforces'>Codeforces</Link></li>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/ps/contests'>Contests</Link></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<br></br>\r\n\t\t\t\t\t<li><Link exact to='/cybersecurity'>Cybersecurity</Link></li>\r\n\t\t\t\t\t<br></br>\r\n\t\t\t\t\t<li>Programming</li>\r\n\t\t\t\t\t{/* <li><Link exact to='/programming'>Programming</Link></li> */}\r\n\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/programming/web'>Web</Link></li>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/programming/game'>Game</Link></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t\t<br></br>\r\n\t\t\t\t\t<li>Games</li>\r\n\t\t\t\t\t{/* <li><Link exact to='/games'>Games</Link></li> */}\r\n\t\t\t\t\t<ul>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/games/chess'>Chess</Link></li>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/games/steam'>Steam</Link></li>\r\n\t\t\t\t\t\t<br></br>\r\n\t\t\t\t\t\t<li><Link exact to='/games/ns'>Nintendo Switch</Link></li>\r\n\t\t\t\t\t</ul>\r\n\t\t\t\t</ul>\r\n\t\t\t </div>\r\n        </div>\r\n    )\r\n};\r\n\r\nexport default Sidebar;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Algorithms.js",["98"],[],"import \"../../Content.css\"\r\n\r\nconst d = <div className=\"f\"></div>\r\n\r\nconst Algorithms = () => {\r\n\treturn (\r\n\t\t<div className=\"content\">\r\n\t\t\t<h2 className=\"category\">Algorithms</h2>\r\n\t\t\t\r\n\t\t\t<h1 className=\"title\">test</h1>\r\n\t\t\t<p>test content</p>\r\n\t\t\t<a className=\"date\">2023-07-03</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d}\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default Algorithms;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\programming\\Web.js",["99"],[],"import '../../Content.css';\r\nimport { Link } from 'react-router-dom';\r\n\r\nconst d = <div className=\"f\"></div>\r\n\r\nconst Web = () => {\r\n\treturn (\r\n\t\t<div className=\"content\">\r\n\t\t\t<h2 className=\"category\"><Link exact to='/programming/web'>Web</Link></h2>\r\n\t\t\t\r\n\t\t\t<h1 className=\"title\">생애 첫 블로그 만들기</h1>\r\n\t\t\t<p>깃허브에서 제공하는 기능을 통해 무료로 커스터마이징이 가능한 블로그를 운영할 수 있게 되었다.</p>\r\n\t\t\t<p>그래서 만들어 보았다!</p>\r\n\t\t\t<p>그렇게 나는 React도 연습할 겸, React를 통해 그리 어렵지 않게, 단순한 형태의 블로그를 완성할 수 있었다.</p>\r\n\t\t\t<p>그런데 문제는, 이 깃허브 블로그는 정적 웹 페이지이기 때문에 DB연동 등과 같은 일부 기능을 이용할 수가 없다.</p>\r\n\t\t\t<p>그래서 채택한 방법이 있다. 글을 쓸 때 직접 vscode를 열어서 마치 코딩하는 것처럼 불편하게 작성하는 것이다!</p>\r\n\t\t\t<p>깃허브가 1GB가 넘어가면 따로 요금을 청구한다는데 이것도 나름 큰일이다.</p>\r\n\t\t\t<p>이걸로 좀 쓰다가 워드프레스나 티스토리나 뭐 이런걸로 넘어가야지..</p>\r\n\t\t\t<a className=\"date\">Jul. 3rd, 2023</a>\r\n\t\t\t<br></br>\r\n\t\t\t{d}\r\n\t\t</div>\r\n\t)\r\n};\r\n\r\nexport default Web;","C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\BOJ.js",[],[],"C:\\Users\\dbsdk\\OneDrive\\문서\\GitHub\\ramzxc.github.io\\src\\categories\\ps\\Codeforc